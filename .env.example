# RTMP Server Configuration

# Ports
RTMP_PORT=1935
HTTP_PORT=80
HTTPS_PORT=443

# Connection Settings
MAX_CONNECTIONS=1000
MAX_STREAMS=50
STREAM_TIMEOUT=300
DROP_IDLE_PUBLISHER=300

# HLS Settings
HLS_ENABLED=true
HLS_FRAGMENT_DURATION=2
HLS_PLAYLIST_LENGTH=3

# DASH Settings
DASH_ENABLED=true
DASH_FRAGMENT_DURATION=2
DASH_PLAYLIST_LENGTH=3

# Recording Settings
RECORD_ENABLED=false
RECORD_PATH=/var/streaming/recordings
RECORD_FORMAT=flv

# SSL/TLS Settings (optional)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem

# Logging
LOG_LEVEL=warn
ACCESS_LOG_ENABLED=true

# Performance Tuning
WORKER_PROCESSES=auto
WORKER_CONNECTIONS=10000
CHUNK_SIZE=4096

# Gzip Compression
GZIP_ENABLED=true
GZIP_COMPRESSION_LEVEL=6

# CORS Settings
CORS_ENABLED=true

# Docker Settings
TZ=UTC
RESTART_POLICY=unless-stopped
